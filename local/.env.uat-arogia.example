# Arogia UAT deployment example
# Copy to local/.env.uat-arogia and replace every CHANGE_ME / SERVER_IP value before deploying.

COMPOSE_PROJECT_NAME=arogia_uat
APP_ENV=uat
CONTAINER_NAME_PREFIX=arogia-uat

BRANDING_PRODUCT_NAME=Arogia
BRANDING_TAGLINE=Smart Healthcare Management Platform
BRANDING_COMPANY_NAME=DeepThoughtNet
BRANDING_AI_PLATFORM_NAME=AIVA

SERVER_IP=CHANGE_ME_SERVER_IP

POSTGRES_DB=arogia_uat
POSTGRES_USER=arogia_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

MINIO_ROOT_USER=arogia_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
CLINIC_MINIO_ACCESS_KEY=arogia_minio
CLINIC_MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD

API_PORT=8089
WEB_ADMIN_PORT=5175
WEB_PUBLIC_PORT=5176
WEB_AIVA_PORT=5177
POSTGRES_PORT=5437
REDIS_PORT=6380
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002
KEYCLOAK_PORT=8090

# External public URLs
API_BASE_URL=https://arogia.deepthoughtnet.com/api
PUBLIC_APP_URL=https://arogia.deepthoughtnet.com
PUBLIC_PORTAL_URL=https://portal.deepthoughtnet.com
KEYCLOAK_URL=https://arogia.deepthoughtnet.com/auth

# Frontend build-time URLs
VITE_API_BASE_URL=https://arogia.deepthoughtnet.com/api
VITE_PUBLIC_API_BASE_URL=https://arogia.deepthoughtnet.com/api
VITE_CLINIC_LOGIN_URL=https://arogia.deepthoughtnet.com
VITE_AIVA_APP_URL=https://portal.deepthoughtnet.com/careai
VITE_CAREAI_RUNTIME_URL=wss://portal.deepthoughtnet.com/ws/patient-portal/careai
VITE_KEYCLOAK_URL=https://arogia.deepthoughtnet.com/auth
VITE_KEYCLOAK_REALM=clinic-management
VITE_KEYCLOAK_CLIENT_ID=clinic-web-admin

SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/arogia_uat
SPRING_DATASOURCE_USERNAME=arogia_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT issuer must match browser-issued Keycloak token issuer.
# JWK and admin URLs are internal Docker URLs and must include /auth because Keycloak runs with KC_HTTP_RELATIVE_PATH=/auth.
CLINIC_JWT_ISSUER_URI=https://arogia.deepthoughtnet.com/auth/realms/clinic-management
CLINIC_JWT_JWK_SET_URI=http://keycloak:8080/auth/realms/clinic-management/protocol/openid-connect/certs
CLINIC_KEYCLOAK_SERVER_URL=http://keycloak:8080/auth

CLINIC_MINIO_ENDPOINT=http://minio:9000
CLINIC_PATIENT_PORTAL_SESSION_SECRET=CHANGE_ME_PATIENT_PORTAL_SESSION_SECRET
VOICE_PATIENT_PORTAL_UPSTREAM_WS_URL=ws://clinic-management-api:8089/ws/patient-portal/careai
CLINIC_CORS_ALLOWED_ORIGINS=https://arogia.deepthoughtnet.com,https://portal.deepthoughtnet.com

CLINIC_AI_ENABLED=true
CLINIC_AI_PROVIDER=GEMINI
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq
AI_PROVIDER_CHAIN=GEMINI,GROQ,MOCK
CLINIC_GEMINI_ENABLED=true
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
CLINIC_GROQ_ENABLED=true
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.1-8b-instant

WHISPER_ENABLED=true
PIPER_ENABLED=true
AIVA_ENABLED=true
VOICE_TEST_ENABLED=true
VOICE_STT_PROVIDER_ORDER=faster-whisper,mock
VOICE_TTS_PROVIDER_ORDER=piper,mock
VOICE_LLM_PROVIDER_ORDER=gemini,groq,mock
FASTER_WHISPER_BASE_URL=http://faster-whisper:8000
PIPER_TTS_BASE_URL=http://piper-tts:8001
PIPER_DEFAULT_VOICE=en_US-lessac-medium
PIPER_ENGLISH_VOICE=en_US-lessac-medium
PIPER_HINDI_VOICE=hi_IN-rohan-medium
PIPER_ALLOW_FALLBACK_VOICE=true
